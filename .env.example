# MiMo API Configuration
# Get your API key from https://platform.xiaomimimo.com/
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_BASE=https://platform.xiaomimimo.com/api/v1
MIMO_MODEL=mimo-v2.5-instruct

# Optional: tune model behavior
# Lower temperature = more deterministic commit messages
MIMO_TEMPERATURE=0.2
MIMO_MAX_TOKENS=512

# Optional: changelog/release behavior
# Default conventional commit types that trigger a minor/major bump
MIMO_MINOR_BUMP_TYPES=feat
MIMO_MAJOR_BUMP_KEYWORDS=BREAKING CHANGE,BREAKING-CHANGE
